# MongoDB — giống DORA backend (mongo local). Local & master đều mongodb://localhost:27017.
MONGODB_URI="mongodb://localhost:27017"

# Generate with: openssl rand -base64 32
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"

# Google OAuth credentials
# Create at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Ably realtime — giống DORA. Local dùng key local; production dùng key master.
ABLY_KEY=""

# Tên DB — giống DORA. Local = "dora"; production (master) = "dora-master".
MONGODB_DB="dora"

# SYSTEM_TOKEN — shared-secret cho /v1 (giống system_token của dora-backend).
# Có thể liệt kê nhiều token (local + master) phân tách bằng dấu phẩy. Bỏ token dev.
SYSTEM_TOKEN=""

# Vercel Blob — lưu ảnh đính kèm (Storage → Blob → token). Bắt buộc cho gửi ảnh.
BLOB_READ_WRITE_TOKEN=""

# Chat-AI — Gemini là provider chính (giống DORA). ChatGPT/Dify là fallback (tuỳ chọn).
GEMINI_API_KEY=""
CHAT_GPT_API_KEY=""
DIFY_API_KEY=""

# Đặt "true" để trả gợi ý AI giả lập (test UI không tốn API).
MOCK_AI_RESPONSE=""

# Cửa sổ (giây) coi tin là "mới" để kích hoạt auto-reply/AI — tránh bão khi sync lịch sử.
AUTO_ACTION_WINDOW_SECONDS="900"

# Bảo vệ Vercel Cron (/api/cron/fetch-orders — tự fetch đơn mỗi 2 tiếng).
# Vercel gửi header "Authorization: Bearer <CRON_SECRET>". Generate: openssl rand -base64 32.
# Local bỏ trống → route không chặn.
CRON_SECRET=""
