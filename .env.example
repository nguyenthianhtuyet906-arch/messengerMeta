# MongoDB Atlas connection string
MONGODB_URI="mongodb+srv://<user>:<password>@<cluster>.mongodb.net/messenger?retryWrites=true&w=majority"

# Generate with: openssl rand -base64 32
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"

# Google OAuth credentials
# Create at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Ably realtime (same key as Meta-extension)
ABLY_KEY=""
MONGODB_DB="meta_local"

# Vercel Blob — lưu ảnh đính kèm (Storage → Blob → token). Bắt buộc cho gửi ảnh.
BLOB_READ_WRITE_TOKEN=""

# Chat-AI — Gemini là provider chính (giống DORA). ChatGPT/Dify là fallback (tuỳ chọn).
GEMINI_API_KEY=""
CHAT_GPT_API_KEY=""
DIFY_API_KEY=""

# Đặt "true" để trả gợi ý AI giả lập (test UI không tốn API).
MOCK_AI_RESPONSE=""

# Cửa sổ (giây) coi tin là "mới" để kích hoạt auto-reply/AI — tránh bão khi sync lịch sử.
AUTO_ACTION_WINDOW_SECONDS="900"
